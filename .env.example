# Шаблон переменных для docker-compose. Скопируй в .env и заполни значения.
# Сильные секреты: openssl rand -hex 32
# --- DB ---
DB_NAME=task_manager
DB_USER=postgres
DB_PASSWORD=
# --- API ---
SECRET_KEY=
# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# --- /metrics basic-auth ---
METRICS_USER=metrics
METRICS_PASSWORD=
